pipeline {
    agent any
    
    triggers {
        // Trigger build on every push to main branch
        pollSCM('H/2 * * * *')  // Poll every 2 minutes for changes
        // Alternative: Use GitHub webhook for instant triggers
    }
    
    environment {
        DOCKER_IMAGE = 'slmakomazi/fullcycle-api'
        // Semantic versioning: v1.${BUILD_NUMBER}
        DOCKER_TAG = "v1.${env.BUILD_NUMBER}"
        DOCKERFILE_PATH = './api/Dockerfile'
        BUILD_CONTEXT = './api'
        GIT_COMMIT_SHORT = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
    }
    
    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/SLMakomazi/FullCycleDevOps.git', changelog: false
            }
        }
        
        stage('Maven Build') {
            steps {
                dir('api') {
                    script {
                        docker.image('maven:3.9.8-eclipse-temurin-17').inside {
                            sh 'mvn clean compile'
                        }
                    }
                }
            }
        }
        
        stage('Maven Test') {
            steps {
                dir('api') {
                    script {
                        docker.image('maven:3.9.8-eclipse-temurin-17').inside {
                            sh 'mvn test -Dsurefire.useFile=true -Dmaven.test.failure.ignore=false'
                        }
                    }
                }
                script {
                    if (fileExists('api/target/surefire-reports')) {
                        junit 'api/target/surefire-reports/*.xml'
                    } else {
                        echo "No test reports found - skipping JUnit publish"
                    }
                }
            }
        }
        
        stage('Docker Build') {
            steps {
                script {
                    echo "Building Docker image with tag: ${DOCKER_TAG}"
                    echo "Git commit: ${GIT_COMMIT_SHORT}"
                    def customImage = docker.build("${DOCKER_IMAGE}:${DOCKER_TAG}", "${BUILD_CONTEXT} -f ${DOCKERFILE_PATH}")
                    docker.withRegistry('', 'docker-hub-cred') {
                        customImage.push()
                    }
                    // Also push with commit hash for traceability
                    docker.withRegistry('', 'docker-hub-cred') {
                        customImage.push("${GIT_COMMIT_SHORT}")
                    }
                }
            }
        }
        
        stage('Docker Tag Latest') {
            steps {
                script {
                    // Tag the semantic version as latest for production deployment
                    def customImage = docker.image("${DOCKER_IMAGE}:${DOCKER_TAG}")
                    docker.withRegistry('', 'docker-hub-cred') {
                        customImage.push('latest')
                    }
                    echo "Tagged ${DOCKER_TAG} as latest"
                }
            }
        }

        stage('Update K8s Manifests') {
            steps {
                script {
                    // Update the newTag property inside the correct directory path layout
                    sh "sed -i 's/newTag:.*/newTag: v1.${BUILD_NUMBER}/g' k8s/local-wsl/kustomization.yaml"
                    
                    // Securely wrap git operations inside your existing github_access credential vault block
                    withCredentials([usernamePassword(credentialsId: 'github_access', passwordVariable: 'GIT_PASSWORD', usernameVariable: 'GIT_USERNAME')]) {
                        sh """
                            git config --global user.email "jenkins@wsl.local"
                            git config --global user.name "Jenkins Automation"
                            git remote set-url origin https://${GIT_USERNAME}:${GIT_PASSWORD}@github.com/SLMakomazi/FullCycleDevOps.git
                            git add k8s/local-wsl/kustomization.yaml
                            git commit -m "chore: jenkins auto-updated overlay image tag to v1.${BUILD_NUMBER}"
                            git push origin main
                        """
                    }
                }
            }
        }
    }
    
    post {
        always {
            cleanWs()
            echo "Pipeline finished - Image tagged as: ${DOCKER_TAG}"
            echo "Git commit: ${GIT_COMMIT_SHORT}"
            echo "Docker image: ${DOCKER_IMAGE}:${DOCKER_TAG}"
        }
        success {
            echo "✅ Build successful!"
            echo "📦 Docker images pushed:"
            echo "   - ${DOCKER_IMAGE}:${DOCKER_TAG} (semantic version)"
            echo "   - ${DOCKER_IMAGE}:${GIT_COMMIT_SHORT} (commit hash)"
            echo "   - ${DOCKER_IMAGE}:latest (production tag)"
        }
        failure {
            echo "❌ Build failed! Check logs for details."
        }
    }
}
